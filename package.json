{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "portfolio",
  "main": "index.html",
  "scripts": {
    "build": "sass src/scss/main.scss dist/main.css --style=compressed",
    "build:prod": "npm run build && node build.js",
    "watch:css": "sass --watch src/scss/main.scss:dist/main.css --style=expanded",
    "serve": "npx serve .",
    "dev": "npm run watch:css & npm run serve"
  },
  "author": "vaibhavmande",
  "devDependencies": {
    "sass": "^1.77.0",
    "serve": "^14.2.0"
  }
}
